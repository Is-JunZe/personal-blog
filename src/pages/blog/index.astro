---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`博客 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <h1>📝 所有文章</h1>
        <p class="section-desc">共 {posts.length} 篇文章</p>

        {
          posts.length === 0 ? (
            <p class="empty-state">还没有文章，马上就来！🚀</p>
          ) : (
            <div class="blog-grid">
              {posts.map((post) => (
                <article class="blog-card card">
                  <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="blog-link">
                    <div class="blog-info">
                      <h3>{post.data.title}</h3>
                      <p class="blog-desc">{post.data.description}</p>
                      <div class="blog-meta">
                        <span class="blog-date">
                          <FormattedDate date={post.data.pubDate} />
                        </span>
                        {post.data.tags && post.data.tags.length > 0 && (
                          <span class="blog-tags">
                            {post.data.tags.slice(0, 3).map((tag: string) => (
                              <span class="tag">{tag}</span>
                            ))}
                          </span>
                        )}
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          )
        }
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 960px;
    max-width: calc(100% - 2em);
  }

  .section-desc {
    color: rgb(var(--text-muted));
    margin-bottom: 2em;
    font-size: 0.95em;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2em;
  }

  .blog-card {
    padding: 0;
    overflow: hidden;
  }

  .blog-card:first-child {
    grid-column: 1 / -1;
  }

  .blog-link {
    display: block;
    padding: 1.5em;
    color: inherit;
    text-decoration: none;
    border-bottom: none;
  }
  .blog-link:hover {
    color: inherit;
    text-shadow: none;
    border-bottom: none;
  }

  .blog-info h3 {
    font-size: 1.2em;
    margin-bottom: 0.4em;
    transition: color 0.2s;
  }
  .blog-link:hover h3 {
    color: var(--accent);
  }

  .blog-card:first-child .blog-info h3 {
    font-size: 1.6em;
  }

  .blog-desc {
    color: rgb(var(--text-secondary));
    font-size: 0.9em;
    margin-bottom: 0.8em;
    line-height: 1.6;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 0.6em;
    flex-wrap: wrap;
  }

  .blog-date {
    color: rgb(var(--text-muted));
    font-size: 0.8em;
  }

  .blog-tags {
    display: flex;
    gap: 0.3em;
    flex-wrap: wrap;
  }

  .blog-tags .tag {
    font-size: 0.7em;
    padding: 2px 8px;
  }

  .empty-state {
    text-align: center;
    color: rgb(var(--text-muted));
    padding: 3em 0;
    font-size: 1.2em;
  }

  @media (max-width: 720px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    .blog-card:first-child {
      grid-column: 1;
    }
    .blog-card:first-child .blog-info h3 {
      font-size: 1.2em;
    }
  }
</style>
