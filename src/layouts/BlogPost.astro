---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <BaseHead title={`${title} - ${SITE_TITLE}`} description={description} />
    <style>
      article {
        max-width: 780px;
        margin: 0 auto;
      }
      .hero-image {
        width: 100%;
        margin-bottom: 2em;
      }
      .hero-image img {
        display: block;
        margin: 0 auto;
        border-radius: 16px;
        box-shadow: var(--box-shadow);
      }
      .post-header {
        text-align: center;
        margin-bottom: 2.5em;
      }
      .post-header h1 {
        margin-bottom: 0.3em;
      }
      .post-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1em;
        flex-wrap: wrap;
        color: rgb(var(--text-muted));
        font-size: 0.9em;
      }
      .update-date {
        font-style: italic;
        color: rgb(var(--text-secondary));
      }
      .post-tags {
        display: flex;
        justify-content: center;
        gap: 0.4em;
        margin-top: 0.8em;
        flex-wrap: wrap;
      }
      .prose {
        width: 100%;
        color: rgb(var(--text-primary));
      }
      .prose :global(h2) {
        margin-top: 2em;
        padding-bottom: 0.3em;
        border-bottom: 1px solid rgb(var(--border-color));
      }
      .prose :global(h3) {
        margin-top: 1.5em;
      }
      .prose :global(p) {
        margin-bottom: 1.5em;
        color: rgb(var(--text-secondary));
        line-height: 1.9;
      }
      .prose :global(strong) {
        color: var(--accent);
      }
      .prose :global(img) {
        margin: 1.5em 0;
      }
      .prose :global(ul), .prose :global(ol) {
        color: rgb(var(--text-secondary));
        padding-left: 1.5em;
      }
      .prose :global(li) {
        margin-bottom: 0.5em;
      }
      .back-link {
        display: inline-block;
        margin-top: 3em;
        color: var(--accent);
        font-size: 0.95em;
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        {heroImage && (
          <div class="hero-image">
            <Image width={1020} height={510} src={heroImage} alt={title} />
          </div>
        )}
        <div class="post-header">
          <h1>{title}</h1>
          <div class="post-meta">
            <span>📅 <FormattedDate date={pubDate} /></span>
            {updatedDate && (
              <span class="update-date">
                ✏️ 更新于 <FormattedDate date={updatedDate} />
              </span>
            )}
            <span>📖 {Math.ceil(String(Astro.props).length / 500)} min read</span>
          </div>
          {tags && tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        <div class="prose">
          <slot />
        </div>
        <a href="/blog" class="back-link">← 返回文章列表</a>
      </article>
    </main>
    <Footer />
  </body>
</html>
