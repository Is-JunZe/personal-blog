---
import { SITE_TITLE } from '../consts';
---

<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h3>{SITE_TITLE}</h3>
      <p>🎮 Game · Code · Life</p>
    </div>
    <div class="footer-section">
      <h4>导航</h4>
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
    </div>
    <div class="footer-section">
      <h4>链接</h4>
      <a href="/rss.xml" target="_blank">RSS Feed</a>
      <a href="https://github.com" target="_blank">GitHub</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} {SITE_TITLE}. Built with ❤️ using Astro.</p>
  </div>
</footer>

<style>
  footer {
    margin-top: 4em;
    padding: 3em 1.5em 1.5em;
    background: rgb(var(--bg-secondary));
    border-top: 1px solid rgb(var(--border-color));
  }

  .footer-content {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2em;
  }

  .footer-section h3 {
    background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: 1.3em;
    margin-bottom: 0.5em;
  }

  .footer-section h4 {
    color: rgb(var(--text-primary));
    font-size: 1em;
    margin-bottom: 0.8em;
  }

  .footer-section p {
    color: rgb(var(--text-secondary));
    font-size: 0.95em;
  }

  .footer-section a {
    display: block;
    color: rgb(var(--text-secondary));
    text-decoration: none;
    border-bottom: none;
    padding: 0.3em 0;
    font-size: 0.95em;
    transition: color 0.2s;
  }

  .footer-section a:hover {
    color: var(--accent);
    text-shadow: none;
    border-bottom: none;
  }

  .footer-bottom {
    max-width: 1100px;
    margin: 2em auto 0;
    padding-top: 1.5em;
    border-top: 1px solid rgb(var(--border-color));
    text-align: center;
  }

  .footer-bottom p {
    color: rgb(var(--text-muted));
    font-size: 0.85em;
    margin: 0;
  }

  @media (max-width: 600px) {
    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }
</style>
